{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devpablocristo.local/contracts/ai/capabilities/v1/capability-manifest.schema.json",
  "title": "Capability Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "product",
    "version",
    "tenant_scope",
    "name",
    "description",
    "agents",
    "tools"
  ],
  "properties": {
    "schema_version": {
      "const": "capability_manifest.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "product": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "tenant_scope": {
      "type": "string",
      "enum": ["global", "org", "project"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/tool"
      }
    }
  },
  "$defs": {
    "json_schema_object": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "const": "object"
        }
      },
      "additionalProperties": true
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires_approval"],
      "properties": {
        "requires_approval": {
          "type": "boolean"
        },
        "action_type": {
          "type": "string",
          "minLength": 1
        },
        "target_system": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "mode",
        "side_effect",
        "risk_class",
        "input_schema",
        "required_roles",
        "required_modules",
        "evidence_fields",
        "executor_ref"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["read", "write"]
        },
        "side_effect": {
          "type": "boolean"
        },
        "risk_class": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "input_schema": {
          "$ref": "#/$defs/json_schema_object"
        },
        "output_schema": {
          "$ref": "#/$defs/json_schema_object"
        },
        "required_roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_modules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "executor_ref": {
          "type": "string",
          "minLength": 1
        },
        "governance": {
          "$ref": "#/$defs/governance"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "read"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "side_effect": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "write"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["governance"],
            "properties": {
              "side_effect": {
                "const": true
              },
              "evidence_fields": {
                "minItems": 1
              },
              "governance": {
                "required": ["requires_approval", "action_type"],
                "properties": {
                  "requires_approval": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      ]
    }
  },
  "x-hard-rules": [
    "tool.name values must be unique even when tool objects differ",
    "manifests must not contain URLs, tokens, secrets, credentials, DSNs, hosts, or environment-specific configuration"
  ]
}
