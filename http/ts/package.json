{
  "name": "@devpablocristo/core-http",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./fetch": "./src/fetch.ts",
    "./errors": "./src/errors.ts",
    "./sse": "./src/sse.ts"
  },
  "scripts": {
    "test": "vitest run --environment jsdom --globals",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx"
  ],
  "publishConfig": {
    "access": "public"
  }
}
